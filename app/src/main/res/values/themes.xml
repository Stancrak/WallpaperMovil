<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Base theme for the app. Compose handles Material 3 theming at runtime;
        this XML theme only provides the window background and status bar style.
    -->
    <style name="Theme.WallpaperMovil" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
